  {
    "action": "network.request",
    "category": "network",
    "title": "Network Request",
    "description": "Send an HTTP or HTTPS request through the ArkTS runtime.",
    "params": [
      { "name": "url", "type": "string", "required": true, "description": "Absolute HTTP or HTTPS URL." },
      { "name": "method", "type": "NetworkMethod", "required": false, "description": "GET, POST, PUT or DELETE." },
      { "name": "headers", "type": "NetworkHeaders", "required": false, "description": "String request headers." },
      { "name": "body", "type": "string", "required": false, "description": "Request body for non-GET methods." },
      { "name": "timeout", "type": "number", "required": false, "description": "Native request timeout in milliseconds." },
      { "name": "responseType", "type": "NetworkResponseType", "required": false, "description": "text or json." }
    ],
    "response": [
      { "name": "ok", "type": "boolean", "required": true, "description": "Whether the HTTP status is in the 2xx range." },
      { "name": "statusCode", "type": "number", "required": true, "description": "HTTP status code." },
      { "name": "statusText", "type": "string", "required": false, "description": "Standard text for known HTTP status codes." },
      { "name": "headers", "type": "NetworkHeaders", "required": true, "description": "HTTP response headers." },
      { "name": "body", "type": "NetworkBody", "required": true, "description": "Text or parsed JSON response body." },
      { "name": "duration", "type": "number", "required": true, "description": "Native request duration in milliseconds." }
    ],
    "errors": [
      "PARAM_ERROR",
      "NETWORK_INVALID_URL",
      "NETWORK_UNSUPPORTED_PROTOCOL",
      "NETWORK_TIMEOUT",
      "NETWORK_REQUEST_FAILED",
      "NETWORK_INVALID_RESPONSE",
      "NETWORK_ABORTED",
      "TIMEOUT",
      "CALLBACK_LOST"
    ],
    "implemented": true,
    "biz": "NetworkBiz",
    "imp": "NetworkImp",
    "example": "window.myascf.send(\"network.request\", { url: \"https://example.com\", method: \"GET\" })"
  },
  {
    "action": "network.abort",
    "category": "network",
    "title": "Abort Network Request",
    "description": "Internal action used by the H5 SDK to cancel an active network.request.",
    "params": [
      { "name": "targetRequestId", "type": "string", "required": true, "description": "requestId of the active network.request." }
    ],
    "response": [
      { "name": "targetRequestId", "type": "string", "required": true, "description": "Target requestId." },
      { "name": "aborted", "type": "boolean", "required": true, "description": "Whether an active request was aborted." },
      { "name": "reason", "type": "string", "required": false, "description": "REQUEST_NOT_FOUND when no active request exists." }
    ],
    "errors": ["PARAM_ERROR", "INTERNAL_ERROR", "TIMEOUT", "CALLBACK_LOST"],
    "implemented": true,
    "biz": "NetworkAbortBiz",
    "imp": "NetworkRequestRegistry",
    "example": "window.myascf.send(\"network.abort\", { targetRequestId: \"myascf_xxx\" })",
    "internal": true
  }
]
