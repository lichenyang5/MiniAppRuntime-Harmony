{
  "name": "@lichenyang5/miniapp-runtime-harmony-web-sdk",
  "version": "0.1.0",
  "description": "H5 JavaScript SDK for the MiniAppRuntime-Harmony JSBridge.",
  "private": false,
  "type": "module",
  "main": "./dist/index.esm.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "default": "./dist/index.esm.js"
    },
    "./iife": {
      "types": "./dist/myascf.d.ts",
      "default": "./dist/myascf.js"
    }
  },
  "sideEffects": [
    "./dist/myascf.js"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.js",
    "typecheck": "tsc -p tsconfig.json",
    "prebuild": "node ../tools/generate-sdk-types.js",
    "build": "npm run clean && npm run typecheck && npm run build:esm && npm run build:iife && npm run build:types",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --platform=browser --target=es2017 --outfile=dist/index.esm.js",
    "build:iife": "esbuild src/auto-init.ts --bundle --format=iife --platform=browser --target=es2017 --global-name=MyASCFWebSDK --outfile=dist/myascf.js",
    "build:types": "tsc -p tsconfig.types.json && node scripts/create-legacy-types.js",
    "copy:demo": "node scripts/copy-to-demo.js",
    "build:demo": "npm run build && npm run copy:demo",
    "test:unit": "node --test tests/sdk.test.js",
    "test": "npm run build && npm run test:unit",
    "check": "node ../tools/check-generated-files.js && npm run build && npm run test:unit && npm run pack:dry-run",
    "prepack": "npm run build && npm run test:unit",
    "pack:dry-run": "npm pack --dry-run --ignore-scripts",
    "pack:check": "npm run build && npm run pack:dry-run",
    "pack:local": "npm pack",
    "prepublishOnly": "npm run check"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lichenyang5/MiniAppRuntime-Harmony.git"
  },
  "homepage": "https://github.com/lichenyang5/MiniAppRuntime-Harmony#readme",
  "bugs": {
    "url": "https://github.com/lichenyang5/MiniAppRuntime-Harmony/issues"
  },
  "license": "MIT",
  "keywords": [
    "HarmonyOS",
    "ArkWeb",
    "JSBridge",
    "WebView",
    "H5",
    "ArkTS"
  ],
  "devDependencies": {
    "esbuild": "0.28.1",
    "typescript": "5.7.2"
  }
}
