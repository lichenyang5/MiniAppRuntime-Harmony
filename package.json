{
  "name": "miniapp-runtime-harmony-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Local tooling for the MiniAppRuntime-Harmony open-source demo",
  "author": "Li Chenyang",
  "scripts": {
    "docs:api": "node tools/generate-api-docs.js",
    "sdk:types": "node tools/generate-sdk-types.js",
    "generate": "npm run docs:api && npm run sdk:types",
    "check:generated": "node tools/check-generated-files.js",
    "check:api": "node tools/check-api-consistency.js",
    "check:package": "node tools/check-package-exports.js",
    "check:docs": "node scripts/check-doc-links.mjs",
    "check:public": "node scripts/check-public-content.mjs",
    "check:har-release": "node scripts/check-har-release.mjs --metadata-only",
    "check": "npm run check:generated && npm run check:api && npm run h5:check && npm run check:package && npm run check:docs && npm run check:public && npm run check:har-release",
    "h5:build": "npm --prefix h5_sdk run build",
    "h5:sync": "npm --prefix h5_sdk run build:demo",
    "h5:test": "npm --prefix h5_sdk run test",
    "h5:check": "npm --prefix h5_sdk run check"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "keywords": [],
  "license": "ISC"
}
